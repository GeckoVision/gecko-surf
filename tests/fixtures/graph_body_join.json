{
  "openapi": "3.0.3",
  "info": { "title": "Body-Join Fixture", "version": "1.0.0" },
  "paths": {
    "/orders": {
      "post": {
        "operationId": "createOrder",
        "summary": "Create an order",
        "responses": {
          "200": {
            "description": "created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "orderId": { "type": "string", "format": "uuid" },
                    "status": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/shipments": {
      "post": {
        "operationId": "createShipment",
        "summary": "Create a shipment for an order",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["orderId", "address"],
                "properties": {
                  "orderId": { "type": "string", "format": "uuid" },
                  "address": { "type": "string" },
                  "note": { "type": "string" }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "shipped",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "shipmentId": { "type": "string" } }
                }
              }
            }
          }
        }
      }
    }
  }
}
