{
  "openapi": "3.0.0",
  "info": {
    "title": "Tiny API",
    "description": "A minimal public API used to exercise comprehension end to end.",
    "version": "1.0.0"
  },
  "servers": [{ "url": "https://api.tiny.example.com" }],
  "paths": {
    "/ping": {
      "get": {
        "operationId": "ping",
        "summary": "Health check ping.",
        "responses": {
          "200": {
            "description": "pong",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "pong": { "type": "boolean" } }
                }
              }
            }
          }
        }
      }
    }
  }
}
